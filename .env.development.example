# ─────────────────────────────────────────────────────────────────────────────
# DEVELOPMENT environment (local machine + Docker compose).
# Copy to `.env.development` and adjust if needed. Loaded automatically when
# NODE_ENV=development (default for `pnpm dev`).
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://naqla:naqla_dev_pass@localhost:5432/naqla_dev

# ─── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ─── JWT (development-only secrets; replace per environment) ───
JWT_SECRET=dev-secret-key-min-32-chars-change-in-prod
JWT_REFRESH_SECRET=dev-refresh-secret-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── MinIO (S3-compatible storage) ─────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=naqla-dev
MINIO_PUBLIC_URL=http://localhost:9000

# ─── App ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_NAME=Naqla
APP_URL=http://localhost:4000
APP_DOMAIN=localhost
FRONTEND_URL=http://localhost:3000
FRONTEND_CLIENT_URL=http://localhost:3002
FRONTEND_CARRIER_URL=http://localhost:3003
FRONTEND_ADMIN_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004

# ─── Payment Provider ──────────────────────────────────────────
PAYMENT_PROVIDER=mock
MOYASAR_API_KEY=
TAP_API_KEY=

# ─── SMS Provider ──────────────────────────────────────────────
SMS_PROVIDER=console
UNIFONIC_APP_SID=
UNIFONIC_API_KEY=
MSEGAT_USERNAME=
MSEGAT_API_KEY=
MSEGAT_USERSENDER=Naqla

# ─── Security ──────────────────────────────────────────────────
BCRYPT_ROUNDS=12
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ─── Observability ─────────────────────────────────────────────
SENTRY_DSN=

# ─── Public API URLs (used by web apps) ────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_MINIO_URL=http://localhost:9000
NEXT_PUBLIC_LANDING_URL=http://localhost:3000
NEXT_PUBLIC_CLIENT_URL=http://localhost:3002
NEXT_PUBLIC_CARRIER_URL=http://localhost:3003
