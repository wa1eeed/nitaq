# ─────────────────────────────────────────────────────────────────────────────
# LEGACY TEMPLATE — kept for backward compat. New deploys should copy from one
# of the environment-specific templates instead:
#   • .env.development.example  → local dev
#   • .env.staging.example      → staging
#   • .env.production.example   → production
# See docs/DEPLOYMENT.md for the multi-environment workflow.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://naqla:naqla_dev_pass@localhost:5432/naqla_dev

# ─── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ─── JWT ───────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-strong-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-to-another-strong-secret-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── MinIO (S3-compatible storage) ─────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=naqla-files
MINIO_PUBLIC_URL=http://localhost:9000

# ─── App ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_NAME=Naqla
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# ─── Payment Provider ──────────────────────────────────────────
PAYMENT_PROVIDER=MOCK
MOYASAR_API_KEY=
TAP_API_KEY=

# ─── SMS Provider ──────────────────────────────────────────────
SMS_PROVIDER=console
UNIFONIC_APP_SID=
UNIFONIC_API_KEY=
MSEGAT_USERNAME=
MSEGAT_API_KEY=
MSEGAT_USERSENDER=Naqla

# ─── Security ──────────────────────────────────────────────────
BCRYPT_ROUNDS=12
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ─── Public API URLs (used by web apps) ────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_MINIO_URL=http://localhost:9000
