# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION environment. ALL placeholders MUST be replaced with truly random,
# securely-stored secrets BEFORE deployment. Never commit the populated file.
# Recommended: store production secrets in a vault (Doppler / HashiCorp Vault /
# AWS Secrets Manager / 1Password) and inject at container startup.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://naqla:PROD_DB_PASS@supabase-db:5432/naqla_prod

# ─── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://default:PROD_REDIS_PASS@redis:6379/0
REDIS_PASSWORD=PROD_REDIS_PASS

# ─── JWT (≥ 64 chars, generated via `openssl rand -hex 32`) ────
JWT_SECRET=PROD_JWT_SECRET_MIN_64_CHARS_TRULY_RANDOM_PLACEHOLDER_VALUE_HERE_REPLACE_BEFORE
JWT_REFRESH_SECRET=PROD_REFRESH_SECRET_MIN_64_CHARS_TRULY_RANDOM_PLACEHOLDER_VALUE_HERE_REPLACE
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── MinIO ─────────────────────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=true
MINIO_ROOT_USER=PROD_MINIO_USER
MINIO_ROOT_PASSWORD=PROD_MINIO_PASS
MINIO_BUCKET=naqla-prod
MINIO_PUBLIC_URL=https://storage.naqla.sa

# ─── App ───────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
APP_NAME=Naqla
APP_URL=https://api.naqla.sa
FRONTEND_URL=https://naqla.sa
CORS_ORIGINS=https://naqla.sa,https://admin.naqla.sa,https://app.naqla.sa,https://carrier.naqla.sa,https://driver.naqla.sa

# ─── Payment Provider (live) ───────────────────────────────────
PAYMENT_PROVIDER=moyasar
MOYASAR_API_KEY=PROD_MOYASAR_API_KEY
TAP_API_KEY=

# ─── SMS Provider (live) ───────────────────────────────────────
SMS_PROVIDER=unifonic
UNIFONIC_APP_SID=PROD_UNIFONIC_APP_SID
UNIFONIC_API_KEY=PROD_UNIFONIC_API_KEY
MSEGAT_USERNAME=
MSEGAT_API_KEY=
MSEGAT_USERSENDER=Naqla

# ─── Security ──────────────────────────────────────────────────
BCRYPT_ROUNDS=12
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ─── Observability ─────────────────────────────────────────────
SENTRY_DSN=YOUR_PRODUCTION_SENTRY_DSN_HERE

# ─── Public API URLs ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.naqla.sa
NEXT_PUBLIC_WS_URL=wss://api.naqla.sa
NEXT_PUBLIC_MINIO_URL=https://storage.naqla.sa
