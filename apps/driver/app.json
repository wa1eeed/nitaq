{
  "expo": {
    "name": "نقلة — للسائقين",
    "slug": "naqla-driver",
    "version": "1.0.0",
    "scheme": "naqla-driver",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "sa.nqlah.driver"
    },
    "android": {
      "package": "sa.nqlah.driver",
      "adaptiveIcon": {
        "backgroundColor": "#0A7EA4",
        "foregroundImage": "./assets/icon.png"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "يحتاج التطبيق للموقع لتتبع رحلتك."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "يحتاج التطبيق للكاميرا لتصوير إثبات التسليم."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "يحتاج التطبيق للصور لرفع إثبات التسليم."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0A7EA4"
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
