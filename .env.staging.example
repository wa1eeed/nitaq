# ─────────────────────────────────────────────────────────────────────────────
# STAGING environment. Replace placeholders (UPPERCASE_PASS) with real values
# in the deployment .env.staging file — NEVER commit those.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://naqla:STAGING_DB_PASS@supabase-db:5432/naqla_staging

# ─── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://default:STAGING_REDIS_PASS@redis:6379/1
REDIS_PASSWORD=STAGING_REDIS_PASS

# ─── JWT (must be ≥ 64 chars, truly random) ────────────────────
JWT_SECRET=STAGING_JWT_SECRET_MIN_64_CHARS_RANDOM_PLACEHOLDER_VALUE_HERE_REPLACE_BEFORE_DEPLOY
JWT_REFRESH_SECRET=STAGING_REFRESH_SECRET_MIN_64_CHARS_RANDOM_PLACEHOLDER_VALUE_HERE_REPLACE
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── MinIO ─────────────────────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=STAGING_MINIO_USER
MINIO_ROOT_PASSWORD=STAGING_MINIO_PASS
MINIO_BUCKET=naqla-staging
MINIO_PUBLIC_URL=https://storage.staging.naqla.sa

# ─── App ───────────────────────────────────────────────────────
NODE_ENV=staging
PORT=4000
APP_NAME=Naqla
APP_URL=https://api.nqlah.nx.sa
APP_DOMAIN=nqlah.nx.sa
FRONTEND_URL=https://nqlah.nx.sa
FRONTEND_CLIENT_URL=https://app.nqlah.nx.sa
FRONTEND_CARRIER_URL=https://carrier.nqlah.nx.sa
FRONTEND_ADMIN_URL=https://admin.nqlah.nx.sa
CORS_ORIGINS=https://nqlah.nx.sa,https://admin.nqlah.nx.sa,https://app.nqlah.nx.sa,https://carrier.nqlah.nx.sa

# ─── Payment Provider (still mock on staging unless explicitly testing) ───
PAYMENT_PROVIDER=mock
MOYASAR_API_KEY=
TAP_API_KEY=

# ─── SMS Provider ──────────────────────────────────────────────
SMS_PROVIDER=console
UNIFONIC_APP_SID=
UNIFONIC_API_KEY=

# ─── Security ──────────────────────────────────────────────────
BCRYPT_ROUNDS=12
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ─── Observability ─────────────────────────────────────────────
SENTRY_DSN=YOUR_STAGING_SENTRY_DSN_HERE

# ─── Public API URLs ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.nqlah.nx.sa
NEXT_PUBLIC_WS_URL=wss://api.nqlah.nx.sa
NEXT_PUBLIC_MINIO_URL=https://storage.nqlah.nx.sa
NEXT_PUBLIC_LANDING_URL=https://nqlah.nx.sa
NEXT_PUBLIC_CLIENT_URL=https://app.nqlah.nx.sa
NEXT_PUBLIC_CARRIER_URL=https://carrier.nqlah.nx.sa
